# ─────────────────────────────────────────────────────────────────────
# CONFIGURAÇÕES DO SERVIDOR
# ─────────────────────────────────────────────────────────────────────

# Porta da aplicação (Coolify expõe automaticamente)
PORT=3000

# ─────────────────────────────────────────────────────────────────────
# SEGURANÇA (OBRIGATÓRIO — troque antes de usar em produção)
# ─────────────────────────────────────────────────────────────────────

# Senha para acessar o painel administrativo em /admin
ADMIN_PASSWORD=troque_esta_senha_123

# Segredo para criptografar as sessões (use uma string aleatória longa)
SESSION_SECRET=string_aleatoria_muito_longa_e_secreta_aqui

# ─────────────────────────────────────────────────────────────────────
# E-MAIL (NOTIFICAÇÃO QUANDO CLIENTE ENVIAR ARQUIVOS)
# ─────────────────────────────────────────────────────────────────────
# Para Gmail: ative a verificação em duas etapas na sua conta Google
# e gere uma "Senha de app" em: myaccount.google.com/apppasswords
# Use essa senha de app no campo SMTP_PASS (não a senha normal da conta)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Seu endereço Gmail
SMTP_USER=seuemail@gmail.com

# Senha de app gerada no Google (16 caracteres, sem espaços)
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# E-mail que receberá as notificações (pode ser o mesmo do SMTP_USER)
ADMIN_EMAIL=seuemail@gmail.com
